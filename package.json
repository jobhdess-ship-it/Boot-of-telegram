    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-telegram-bot-api": "^0.64.15",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.25.0",
